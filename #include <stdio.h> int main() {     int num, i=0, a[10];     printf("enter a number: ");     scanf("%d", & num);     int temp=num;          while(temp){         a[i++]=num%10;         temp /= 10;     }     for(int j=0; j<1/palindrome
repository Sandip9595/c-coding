#include <stdio.h>
int main() {
    int num, i=0, a[10];
    printf("enter a number: ");
    scanf("%d", & num);
    int temp=num;
    
    while(temp){
        a[i++]=num%10;
        temp /= 10;
    }
    for(int j=0; j<1/2; j++){
        if(a[j]!=a[i-j-1]){
            printf("it is not a palindrome\n");
            return 0;;
        }
    }
    printf("it is a palindrome\n");
    return 0;
}
